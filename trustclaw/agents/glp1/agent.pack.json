{
  "id": "glp1-eligibility",
  "version": "1.0.0",
  "displayName": {
    "zh-CN": "GLP-1 用药与医保 eligibility",
    "en": "GLP-1 eligibility & NRDL coverage"
  },
  "domain": ["endocrine", "weight-management", "nrdl"],
  "openclaw": {
    "agentId": "main",
    "persona": "C3-PO"
  },
  "tools": {
    "read": "trustclaw_ptds_query",
    "write": "trustclaw_ptds_write"
  },
  "prompts": {
    "system": "prompts/c3po-ptds-system.v1.md",
    "text2sql": "prompts/text2sql.v1.md",
    "personalWrite": "prompts/personal-write-sql.v1.md"
  },
  "data": {
    "readTables": [
      "body_anthropometrics",
      "lab_test_results",
      "clinical_diagnoses",
      "medication_history",
      "user_profile",
      "data_source_registry",
      "medication_compliance_standards",
      "medication_compliance_ast_rules",
      "nrdl_drug_registry",
      "nrdl_payment_rules",
      "nrdl_reference_sync_state",
      "v_glp1_nrdl_check_snapshot"
    ],
    "writeTables": [
      "body_anthropometrics",
      "lab_test_results",
      "daily_vitals",
      "wearable_activity_metrics"
    ],
    "snapshotView": "v_glp1_nrdl_check_snapshot"
  },
  "rules": {
    "engine": "ast-compliance",
    "activeStandardHint": "glp1-nrdl-ast-handshake-v2",
    "drugIdResolver": "glp1-default"
  },
  "pipeline": {
    "stages": ["TEXT2SQL_GEN", "DB_QUERY", "RULE_EVAL", "AGENT_DECISION", "LEDGER_COMMIT"],
    "decisionBuilder": "glp1-decision"
  },
  "consent": {
    "read": { "allowAlways": true },
    "write": { "allowAlways": false }
  },
  "audit": {
    "businessComponent": "PTDS.Agent.GLP1",
    "decisionComponent": "Agent.GLP1Decision",
    "ruleEvalComponent": "AgentRuntime.ExecRule"
  }
}
