{
  "pack_id": "medical-insurance-full-chain-1000",
  "pack_name": "医保医药报销全链路 Domain Agent Pack",
  "version": "2.0.0",
  "openclaw_pack_spec": "1.0",
  "author": "TrustClaw PTDS",
  "created_at": "2026-07-05",
  "updated_at": "2026-07-05",
  "description": "覆盖门诊/住院/药店/异地就医/医保稽核/DRG分组/生育保险/大病保险/医疗救助/中医药全链路的医保报销领域 Agent 配置包，共 1000 个 Domain Agent",

  "file_structure": {
    "base_domain_files": [
      "outpatient-agents.json      — 门诊 (12 agents)",
      "inpatient-agents.json       — 住院 (12 agents)",
      "pharmacy-agents.json        — 药店 (10 agents)",
      "cross-region-agents.json    — 异地就医 (10 agents)",
      "audit-agents.json           — 医保稽核 (12 agents)",
      "drg-agents.json             — DRG分组 (10 agents)",
      "maternity-agents.json       — 生育保险 (10 agents)",
      "catastrophic-agents.json    — 大病保险 (10 agents)",
      "medical-assistance-agents.json — 医疗救助 (8 agents)",
      "tcm-agents.json             — 中医药报销 (8 agents)"
    ],
    "generator_script": "scripts/generate-regional-agents.js",
    "generated_output": {
      "all_agents": "scripts/output/agents-all-1000.json  (2.3MB)",
      "index": "scripts/output/agents-index.json  (274KB)",
      "by_domain": "scripts/output/agents-by-domain/*.json  (10 files)"
    }
  },

  "ptds_base_tables": {
    "available": ["anthropometrics", "labs", "diagnoses", "medications"],
    "note": "以上 4 张表已在当前 PTDS 实例中挂载，标注 partial 的 19 个 Agent 可部分激活"
  },

  "ptds_extended_tables_required": [
