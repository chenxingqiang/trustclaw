# TrustClaw Docker 运行配置（复制为 app.env 后修改）
# 参考：选手电脑 ARM64 Docker 应用部署操作说明

# 宿主机映射端口（Control UI / Gateway API：http://<host>:8080/）
APP_PORT=8080

# PTDS Runtime Console（与 dev 一致：http://127.0.0.1:5174/trustclaw/）
TRUSTCLAW_UI_PORT=5174

# Gateway 容器内端口（保持 19001，与 TrustClaw 默认一致）
OPENCLAW_GATEWAY_PORT=19001

# Control UI / API 访问令牌（请改成强随机值）
OPENCLAW_GATEWAY_TOKEN=change-me-trustclaw-demo

# 主聊天模型（Sonnet）
OPENCLAW_PRIMARY_MODEL=anthropic/claude-sonnet-4-6

# Anthropic 代理（与 Claude Code ~/.claude/settings.json 一致）
ANTHROPIC_BASE_URL=https://api.openai-next.com
ANTHROPIC_API_KEY=

# PTDS Text2SQL（可选）
OPENAI_API_KEY=

# 默认领域 Agent Pack
TRUSTCLAW_DEFAULT_AGENT_PACK=glp1-eligibility

TZ=Asia/Shanghai
